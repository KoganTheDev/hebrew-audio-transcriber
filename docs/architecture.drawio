          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="d1_e_bridge" value="«creates, starts»" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;dashed=1;fontSize=10;exitX=0.75;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="d1_mainwindow" target="d1_threadbridge">
