        <mxCell id="d2_subtitle" value="(inside faster_whisper.WhisperModel.transcribe(), wrapped by Transcriber — left)" style="text;html=1;fontSize=11;fontStyle=2;align=left;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1330" y="48" width="560" height="20" as="geometry" />
