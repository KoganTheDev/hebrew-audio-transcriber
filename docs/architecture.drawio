<mxfile host="app.diagrams.net" agent="Claude Code" version="24.7.5">
  <diagram name="Hebrew Audio Transcriber - Architecture" id="architecture-diagram">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1950" pageHeight="900" math="0" shadow="0">
