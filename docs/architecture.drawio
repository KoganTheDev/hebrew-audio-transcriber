<mxfile host="app.diagrams.net" agent="Claude Code" version="24.7.5">
  <diagram name="Hebrew Audio Transcriber - Architecture" id="architecture-diagram">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1250" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Hebrew Audio Transcriber — High-Level Flow" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="150" y="20" width="600" height="30" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="n_start" value="Launch App" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="350" y="80" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="n_file" value="Select Audio File&#10;(hardware specs shown, real duration probed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="170" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="n_model" value="Choose Model&#10;(system recommends one based on hardware + file length)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="280" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- Step 3 trigger -->
        <mxCell id="n_start_transcribe" value="Start Transcription" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="350" y="390" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Background process -->
        <mxCell id="n_worker" value="Transcribe Audio&#10;(faster-whisper, in a separate background process)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="480" width="300" height="70" as="geometry" />
        </mxCell>

        <mxCell id="n_progress_note" value="Live progress + status streamed back\nto the GUI while this runs" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;size=12;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="640" y="490" width="230" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e_worker_note" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="n_worker" target="n_progress_note">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision -->
        <mxCell id="n_decision" value="Succeeded?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="360" y="590" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Failure path -->
        <mxCell id="n_error" value="Show error inline on&#10;Choose Model — user can retry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="640" y="600" width="230" height="60" as="geometry" />
        </mxCell>

        <!-- Success path -->
        <mxCell id="n_result" value="Save Transcript &amp; Show Result" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="720" width="300" height="60" as="geometry" />
        </mxCell>

        <!-- End -->
        <mxCell id="n_end" value="Ready for Next File" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="350" y="820" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Main flow edges (straight vertical) -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_start" target="n_file">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_file" target="n_model">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_model" target="n_start_transcribe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_start_transcribe" target="n_worker">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_worker" target="n_decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e6_no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="n_decision" target="n_error">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6_retry" value="retry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;exitX=1;exitY=0.2;entryX=1;entryY=0;dashed=1;" edge="1" parent="1" source="n_error" target="n_model">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="920" y="315" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e7_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_decision" target="n_result">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_result" target="n_end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9_loop" value="New File" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;exitX=0;exitY=0.5;entryX=0;entryY=0.5;dashed=1;" edge="1" parent="1" source="n_end" target="n_file">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="230" y="845" />
              <mxPoint x="230" y="205" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="leg_title" value="Legend" style="text;html=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1000" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg1" value="GUI step" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="1030" width="150" height="36" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="Background process step" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="210" y="1030" width="150" height="36" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="Error path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="1030" width="150" height="36" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="Decision" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="550" y="1030" width="150" height="36" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
