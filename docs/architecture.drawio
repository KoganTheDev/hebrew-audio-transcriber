          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Bridge between the two processes: two parallel elbowed dependency edges routed entirely through the empty gap between packages -->
        <mxCell id="d1_e_spawn" value="«spawns» multiprocessing.Process&#10;(target=run_transcription_process /&#10;run_calibration_process)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;dashed=1;fontSize=9;exitX=1;exitY=0.3;entryX=0;entryY=0.3;" edge="1" parent="1" source="d1_threadbridge" target="d1_transcriber">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="368" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="d1_e_queueback" value="progress_queue / result_queue&#10;(&quot;progress&quot;, &quot;status&quot;, &quot;finished&quot;, &quot;error&quot;)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;dashed=1;fontSize=9;exitX=1;exitY=0.75;entryX=0;entryY=0.75;startArrow=open;startFill=0;" edge="1" parent="1" source="d1_threadbridge" target="d1_transcriber">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="730" y="392" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="d1_note" value="Why a separate OS process?&#10;PyQt5 and ctranslate2 each bundle their own MSVCP140.dll on Windows.&#10;Loading both in one process caused an intermittent access-violation crash (0xC0000005) —&#10;isolating faster-whisper into its own process sidesteps the conflict entirely." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;size=14;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="460" y="600" width="500" height="80" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="d1_legend_title" value="Legend" style="text;html=1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="710" width="100" height="20" as="geometry" />
        </mxCell>
