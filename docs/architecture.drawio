        </mxCell>

        <mxCell id="d1_e_hw" value="«uses»" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;dashed=1;fontSize=10;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="d1_steps" target="d1_hw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Package: Background Process -->
        <mxCell id="d1_pkgProc" value="«process» Background OS Process (multiprocessing.Process, spawned per run)" style="shape=folder;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;tabWidth=340;tabHeight=26;tabPosition=left;fontStyle=1;fontSize=12;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="760" y="70" width="420" height="420" as="geometry" />
        </mxCell>

