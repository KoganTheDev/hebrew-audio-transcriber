          <mxGeometry x="850" y="180" width="240" height="70" as="geometry" />
        </mxCell>

        <mxCell id="d1_whisper" value="faster_whisper.WhisperModel&#10;«external library»" style="shape=component;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
